---
dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  respect-rules: true
  prefer-h3: true
  default-nameserver:
    - 223.5.5.5
  proxy-server-nameserver:
    - 223.5.5.5
  nameserver:
    - https://dns.google/dns-query
  nameserver-policy:
    geosite:cn:
      - 223.5.5.5
      - 119.29.29.29
    +: https://dns.google/dns-query#DNS
  fallback: []
  fallback-filter:
    geoip: false
    ip-cidr: []
