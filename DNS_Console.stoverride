name: DNS-FINAL-STASH
dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  follow-rule: true
  default-nameserver:
    - 223.5.5.5
  proxy-server-nameserver:
    - 223.5.5.5
  nameserver:
    - system
  dns-hijack:
    - "any:53"
  nameserver-policy:
    "geosite:cn": system
    "*.r7kq-2nfa-hg9x-bt4m-y3pw.sbs": system
    "r7kq-2nfa-hg9x-bt4m-y3pw.sbs": system
    "*": "https://8.8.8.8/dns-query#DNS"
