name: DNS-ULTIMATE-對齊版
dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  follow-rule: true
  default-nameserver:
    - 223.5.5.5
  proxy-server-nameserver:
    - 223.5.5.5
  nameserver:
    - "https://1.1.1.1/dns-query#DNS"
  dns-hijack:
    - "any:53"
    - "tcp://any:53"
  nameserver-policy:
    "geosite:cn": system
    "*.r7kq-2nfa-hg9x-bt4m-y3pw.sbs": system
    "r7kq-2nfa-hg9x-bt4m-y3pw.sbs": system
    "*": "https://1.1.1.1/dns-query#DNS"

