name: DNS-调度台-终极对齐
desc: 物理级封堵系统后门，强制国外解析钻入 DNS 策略组。
dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  follow-rule: true
  prefer-h3: true
  default-nameserver:
    - 223.5.5.5
  proxy-server-nameserver:
    - 223.5.5.5
  nameserver:
    - 8.8.8.8
  dns-hijack:
    - "any:53"
    - "tcp://any:53"
  nameserver-policy:
    # 强制所有国外请求钻进 DNS 策略组
    "*": "https://dns.google/dns-query#DNS"
rules:
  - "IP-CIDR,8.8.8.8/32,DNS"
  - "IP-CIDR,8.8.4.4/32,DNS"
