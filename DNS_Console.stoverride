name: DNS-调度台-终极版
desc: 强制国外解析跟着策略组走，物理级封堵国内泄露。
dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  follow-rule: true
  default-nameserver:
    - 223.5.5.5
  proxy-server-nameserver:
    - 223.5.5.5
  # 【关键改动】主解析器不再用 system，改用 8.8.8.8，配合下方规则强行入组
  nameserver:
    - 8.8.8.8
  nameserver-policy:
    "geosite:cn": system
    "browserleaks.com": "8.8.8.8#DNS"
    "whoer.net": "8.8.8.8#DNS"
    "geosite:geolocation-!cn": "8.8.8.8#DNS"

# 【新增核心】在覆写中直接插入规则，强制绑架 DNS 服务器的 IP
rules:
  - "IP-CIDR,8.8.8.8/32,DNS"
  - "IP-CIDR,1.1.1.1/32,DNS"
