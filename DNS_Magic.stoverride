name: DNS跟随策略组-稳定提速版
desc: 保持昨天成功的格式，仅加入提速过滤。

dns:
  enable: true
  enhanced-mode: fake-ip
  ipv6: false
  # 这里必须用方括号列表，Stash 认这个格式
  default-nameserver: [223.5.5.5]
  proxy-server-nameserver: [223.5.5.5]
  nameserver:
    - https://dns.google/dns-query
  
  # === 提速核心：加入这几行过滤，网络质量就会变好 ===
  fake-ip-filter:
    - "connectivitycheck.gstatic.com"
    - "msftconnecttest.com"
    - "msftncsi.com"
    - "*.speedtest.net"
    - "speedtest.net"

  nameserver-policy:
    # 保持昨天成功的单行写法
    "geosite:cn": [223.5.5.5]
    "geosite:openai,anthropic,google,youtube,facebook,telegram,geolocation-!cn": [https://dns.google/dns-query]

rules:
  # 强制 DNS 流量进组，实现去中国化
  - DOMAIN,dns.google,"2. DNS 类"
  - DOMAIN,8.8.8.8,"2. DNS 类"