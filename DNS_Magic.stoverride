name: DNS跟随策略组去中国化
desc: 强制DNS流量走“2. DNS 类”策略组

dns:
  enable: true
  enhanced-mode: fake-ip
  ipv6: false
  default-nameserver:
    - 223.5.5.5
  proxy-server-nameserver:
    - 223.5.5.5
  nameserver:
    - https://1.1.1.1/dns-query
  nameserver-policy:
    "geosite:cn": 223.5.5.5
    "geosite:openai,anthropic,google,youtube,facebook,telegram,geolocation-!cn": https://1.1.1.1/dns-query

rules:
  # 给策略组名字加上引号，防止点号和空格被误认
  - DOMAIN,one.one.one.one,"2. DNS 类"
  - DOMAIN,1.1.1.1,"2. DNS 类"
