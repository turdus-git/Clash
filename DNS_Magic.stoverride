name: 复刻Clash脚本-最终修复版
desc: 修复223.5.5.5列表报错，实现DNS跟随策略组

dns:
  enable: true
  enhanced-mode: fake-ip
  ipv6: false
  # 核心修复：必须加上方括号 [ ]，将其声明为列表
  default-nameserver: [223.5.5.5]
  proxy-server-nameserver: [223.5.5.5]
  nameserver:
    - https://dns.google/dns-query
  
  # 性能优化：让系统测试和测速不走 Fake-IP
  fake-ip-filter:
    - "*.lan"
    - "connectivitycheck.gstatic.com"
    - "speedtest.net"
    - "*.speedtest.net"
    - "msftconnecttest.com"
    - "msftncsi.com"

  nameserver-policy:
    # 这里的地址也建议加上方括号，保证兼容性
    "geosite:cn": [223.5.5.5]
    "geosite:openai,google,facebook,youtube,telegram,geolocation-!cn": [https://dns.google/dns-query]

rules:
  # 灵魂注入：强制让 DNS 流量打进策略组
  - DOMAIN,dns.google,"2. DNS 类"
  - DOMAIN,8.8.8.8,"2. DNS 类"
  - DOMAIN,8.8.4.4,"2. DNS 类"